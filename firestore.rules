rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /vibes/{vibeId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }
    match /users/{userId} {
      allow read, write: if false;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}