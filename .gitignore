# VIBELAB SPECIFIC

# Local audio stems — these are in Firebase Storage
# Don't push large audio files to git
assets/audio/*.mp3
assets/audio/*.wav
assets/audio/*.ogg

# Keep the folder itself tracked (empty folders need this)
!assets/audio/.gitkeep
!assets/images/.gitkeep

# Any local test exports
*.png
!assets/images/placeholder.png